# ─── Required ────────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public URL Telegram will POST updates to (HTTPS required)
WEBHOOK_HOST=https://your.domain

# ─── Optional ────────────────────────────────────────────────────────────────
# Port the aiohttp server listens on (Telegram allows: 443, 80, 88, 8443)
PORT=8443

# Paths to SSL cert/key (leave empty when TLS is terminated by nginx)
SSL_CERT=
SSL_KEY=

# SQLite database file path
DB_PATH=bot.db
